{
  "name": "autodev-cli",
  "version": "1.4.1",
  "description": "AutoAIDev CLI — autonomous AI task loop with VS Code / Cursor launcher",
  "license": "MIT",
  "bin": {
    "autodev": "./bin/autodev.js"
  },
